 {                                                                                                                 
      "layer": "top",                                                                                               
      "position": "top",                                                                                            
      "height": 26,                                                                                                 
      "modules-left": ["hyprland/workspaces", "sway/workspaces", "sway/mode"],                                                                      
      "modules-center": ["cpu","temperature", "memory", "network", "custom/mullvad"],
      "modules-right": ["pulseaudio", "clock", "tray"],                                          
                                                                                                                    
      "hyprland/workspaces": {                                                                                      
          "format": "{id}"                                                                                          
      },                                                                                                            
      "clock": {                                                                                                    
          "format": "{:%H:%M  %d.%m.%Y}"                                                                            
      },                                                                                                            
      "cpu": {                                                                                                      
          "format": "CPU {usage}%"                                                                                  
      },                                                                                                            
      "memory": {                                                                                                   
          "format": "RAM {percentage}%"                                                                             
      },                                                                                                            
      "pulseaudio": {                                                                                               
          "format": "Vol {volume}%",                                                                                
          "on-click": "pavucontrol"                                                                                 
      },                                                                                                            
      "network": {                                                                                                  
          "format-ethernet": "LAN",                                                                                 
          "format-disconnected": "Offline"                                                                          
      },                                                                                                            
      "tray": {                                                                                                     
          "spacing": 10                                                                                             
      },
      "temperature": {
          "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
          "format": "{temperatureC}°C"
      },
      "custom/mullvad": {
          "exec": "mullvad status | grep -q Connected && echo '{\"text\": \"VPN\", \"class\": \"connected\", \"tooltip\": \"'$(mullvad status | head -2 | tr '\\n' ' ')'\" }' || echo '{\"text\": \"VPN\", \"class\": \"disconnected\", \"tooltip\": \"VPN getrennt\"}'",
          "return-type": "json",
          "interval": 10,
          "on-click": "\"/opt/Mullvad VPN/mullvad-vpn\""
      }
  }                                                                                                                 
            
